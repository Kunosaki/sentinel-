{
  "name": "sentinel",
  "version": "1.0.1",
  "description": "Apple-inspired virus scanner — full system scan, quarantine, and wipe",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "pack": "electron-packager . Sentinel --platform=win32 --arch=x64 --out=release --prune --overwrite"
  },
  "build": {
    "appId": "com.sentinel.antivirus",
    "productName": "Sentinel",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scanner.py",
      "scan_cli.py",
      "malware_hashes.json",
      "node_modules/**/*",
      "!node_modules/electron/dist"
    ],
    "extraResources": [
      "scanner.py",
      "scan_cli.py"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Sentinel-${version}.${ext}"
    },
    "asarUnpack": [
      "scanner.py",
      "scan_cli.py"
    ]
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.0.0",
    "@electron/packager": "^18.3.0"
  }
}
