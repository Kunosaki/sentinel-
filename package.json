{
  "name": "sentinel",
  "version": "1.0.0",
  "description": "Apple-inspired virus scanner — full system scan, quarantine, and wipe",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.sentinel.antivirus",
    "productName": "Sentinel",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scanner.py",
      "scan_cli.py",
      "malware_hashes.json",
      "node_modules/**/*",
      "!node_modules/electron/dist"
    ],
    "extraResources": [
      "scanner.py",
      "scan_cli.py"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null,
      "artifactName": "Sentinel-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Sentinel"
    },
    "asarUnpack": [
      "scanner.py",
      "scan_cli.py"
    ]
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^25.0.0"
  }
}
